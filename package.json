    "supabase:db:reset": "npx supabase db reset",
    "supabase:functions:serve": "npx supabase functions serve",
    "test:resolver": "deno test supabase/functions/_shared/*.test.ts",
    "verify:resolver": "deno run supabase/functions/_shared/verify-resolver.ts",
    "test": "npm run test:resolver"
  },
  "keywords": [],
