{
  "name": "emojiwar",
  "version": "1.0.0",
  "description": "EmojiWar is a portrait mobile 5v5 squad battler for iPhone and Android built around blind bans, formation, and deterministic auto-battle resolution.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
